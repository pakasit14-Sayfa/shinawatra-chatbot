# ==========================================
# 🌍 Global Settings
# ==========================================
PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==========================================
# 🛡️ Security
# ==========================================
FB_APP_SECRET=your_fb_app_secret_here

# ==========================================
# 🏥 1. วิทยาเขตชินวัตร (Shinawatra University)
# ==========================================

# --- Facebook Page: คณะพยาบาลศาสตร์ ---
FB_PAGE_ID_SHINA_NURSE=1234567890_nurse
DIFY_API_KEY_SHINA_NURSE=app-dify-nurse-key

# --- Facebook Page: เพจหลักมหาวิทยาลัย ---
FB_PAGE_ID_SHINA_MAIN=0987654321_main
DIFY_API_KEY_SHINA_MAIN=app-dify-main-key

# --- LINE OA: บัญชีชินวัตร ---
# (ใช้ร่วมกัน หรือแยก Dify ตามต้องการ)
DIFY_API_KEY_SHINA_LINE=app-dify-line-key
LINE_ACCESS_TOKEN_SHINA=line_access_token_shina_here
LINE_CHANNEL_SECRET_SHINA=line_channel_secret_shina_here

# ==========================================
# 🏛️ 2. วิทยาเขตพิษณุโลก (Phitsanulok)
# ==========================================

# --- Facebook Page: PLU Main ---
FB_PAGE_ID_PLU=1122334455_plu
DIFY_API_KEY_PLU=app-dify-plu-key

# --- LINE OA: บัญชี PLU ---
LINE_ACCESS_TOKEN_PLU=line_access_token_plu_here
LINE_CHANNEL_SECRET_PLU=line_channel_secret_plu_here

# ==========================================
# 🇨🇳 3. โปรเจกต์จีน (China)
# ==========================================

# --- Facebook Page: China ---
FB_PAGE_ID_CHINA_1=5566778899_china
DIFY_API_KEY_CHINA=app-dify-china-key

# --- LINE OA: บัญชี China ---
LINE_ACCESS_TOKEN_CHINA=line_access_token_china_here
LINE_CHANNEL_SECRET_CHINA=line_channel_secret_china_here

# ==========================================
# 💾 Database / Redis (Phase 2)
# ==========================================
