# ==========================================
# 🌍 Global Settings
# ==========================================
PORT=3000
DIFY_API_URL=https://api.dify.ai/v1/chat-messages
TIMEZONE=Asia/Bangkok
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# กลุ่มแยกตามแคมปัส - แจ้งบั๊ก/ระบบ error (optional, fallback ไป TELEGRAM_CHAT_ID ถ้าไม่ตั้ง)
TELEGRAM_CHAT_ID_PROJECT_1=
TELEGRAM_CHAT_ID_PROJECT_2=
TELEGRAM_CHAT_ID_PROJECT_3=
# กลุ่มแยกตามเพจ - แจ้งเฉพาะตอน "AI ตอบคำถามลูกค้าไม่ได้" (คนละชุดกับบั๊ก/ระบบ error ข้างบน)
# เพจ 2 (ทั่วไป) และเพจ 3 (พยาบาล) ใช้ chat id เดียวกันได้ถ้าต้องการรวมกลุ่ม
TELEGRAM_CHAT_ID_CANTANSWER_PAGE1=
TELEGRAM_CHAT_ID_CANTANSWER_PAGE2=
TELEGRAM_CHAT_ID_CANTANSWER_PAGE3=
TELEGRAM_CHAT_ID_CANTANSWER_CHINA=

# ==========================================
# 🛡️ Security / Admin
# ==========================================
ADMIN_USER=admin
ADMIN_PASS=plu1234
FB_APP_SECRET=your_fb_app_secret_here
META_VERIFY_TOKEN=your_meta_verify_token_here

# ==========================================
# 💾 Database / Redis
# ==========================================
DATABASE_URL="mysql://root:password@localhost:3306/chatbot_db"
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# 🧠 Dify API Keys (3 สมอง)
# ==========================================
DIFY_API_KEY_BRAIN_1=app-dify-brain-1-key
DIFY_API_KEY_BRAIN_2=app-dify-brain-2-key
DIFY_API_KEY_BRAIN_3=app-dify-brain-3-key

# ==========================================
# 🟢 LINE OA (3 ตัว)
# ==========================================
LINE_TOKEN_1=line_access_token_1_here
LINE_SECRET_1=line_channel_secret_1_here

LINE_TOKEN_2=line_access_token_2_here
LINE_SECRET_2=line_channel_secret_2_here

LINE_TOKEN_3=line_access_token_3_here
LINE_SECRET_3=line_channel_secret_3_here

# ==========================================
# 🔵 Facebook Pages (7 เพจ)
# ==========================================
FB_PAGE_ID_1=1234567890_page1
FB_PAGE_TOKEN_1=fb_page_token_1_here

FB_PAGE_ID_2=1234567890_page2
FB_PAGE_TOKEN_2=fb_page_token_2_here

FB_PAGE_ID_3=1234567890_page3
FB_PAGE_TOKEN_3=fb_page_token_3_here

FB_PAGE_ID_4=1234567890_page4
FB_PAGE_TOKEN_4=fb_page_token_4_here

FB_PAGE_ID_5=1234567890_page5
FB_PAGE_TOKEN_5=fb_page_token_5_here

FB_PAGE_ID_6=1234567890_page6
FB_PAGE_TOKEN_6=fb_page_token_6_here

FB_PAGE_ID_7=1234567890_page7
FB_PAGE_TOKEN_7=fb_page_token_7_here
