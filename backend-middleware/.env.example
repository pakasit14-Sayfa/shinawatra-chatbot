# ==========================================
# 🌍 Global Settings
# ==========================================
PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==========================================
# 🛡️ Security
# ==========================================
FB_APP_SECRET=your_fb_app_secret_here

# ==========================================
# 💾 Database / Redis
# ==========================================
DATABASE_URL="mysql://root:password@localhost:3306/chatbot_db"
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# 🧠 Dify API Keys (3 สมอง)
# ==========================================
DIFY_API_KEY_BRAIN_1=app-dify-brain-1-key
DIFY_API_KEY_BRAIN_2=app-dify-brain-2-key
DIFY_API_KEY_BRAIN_3=app-dify-brain-3-key

# ==========================================
# 🟢 LINE OA (3 ตัว)
# ==========================================
